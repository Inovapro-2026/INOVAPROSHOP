rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['buyer', 'seller'] && // Users can't promote themselves to admin
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.sellerId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.buyerId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'paid', 'delivered', 'completed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                     incoming().role == existing().role && // Role immutable
                     incoming().email == existing().email;
    }

    match /products/{productId} {
      allow read: if true; // Public marketplace
      allow create: if isSeller() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isOwner(existing().sellerId) && isValidProduct(incoming());
      allow delete: if isOwner(existing().sellerId) || isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isSeller() && isValidProduct(incoming()) && isValidId(serviceId);
      allow update: if isOwner(existing().sellerId) && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().buyerId) || isOwner(existing().sellerId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isSignedIn() && (
        // Seller marking as delivered
        (isOwner(existing().sellerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'delivered') ||
        // Buyer confirming completion
        (isOwner(existing().buyerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'completed') ||
        // Admin intervention
        isAdmin()
      );
    }
  }
}
